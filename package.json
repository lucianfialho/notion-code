{
  "name": "notion-code",
  "version": "0.1.0",
  "description": "Claude Code for Notion — manage your Notion workspace from the terminal",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "notion-code": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
